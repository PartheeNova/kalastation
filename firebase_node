<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>IoT Node - Unified Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  <style>
    :root { --bg-color: #f4f7f9; --card-bg: #ffffff; --text-main: #2d3436; --text-muted: #6c757d; --border-color: rgba(0,0,0,0.1); --accent: #1a73e8; }
    [data-theme="dark"] { --bg-color: #121212; --card-bg: #1e1e1e; --text-main: #e0e0e0; --text-muted: #a0a0a0; --border-color: rgba(255,255,255,0.1); }
    
    body { background: var(--bg-color); color: var(--text-main); font-family: 'Inter', sans-serif; transition: all 0.3s ease; }
    .kpi-card { border-radius: 12px; border: 1px solid var(--border-color); background: var(--card-bg); height: 100%; }
    .ribbon-card { border-left: 5px solid var(--accent); }
    .kpi-small-label { font-size: 0.7rem; text-transform: uppercase; font-weight: 700; color: var(--text-muted); }
    .kpi-main-val { font-size: 1.4rem; font-weight: 700; }
    .chart-box { position: relative; height: 250px; width: 100%; background: var(--card-bg); border-radius: 12px; padding: 10px; }
    #map { height: 300px; border-radius: 12px; width: 100%; margin-top: 20px; border: 1px solid var(--border-color); }
    .control-panel { background: var(--card-bg); padding: 12px; border-radius: 12px; border: 1px solid var(--border-color); margin-bottom: 20px; }
    #sync-dot { font-size: 0.7rem; }
  </style>
</head>
<body>

<div class="container-fluid py-3 px-lg-4">
  <header class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h5 class="m-0 fw-bold">IoT Node Gateway <span id="sync-dot" class="badge rounded-pill bg-danger">●</span></h5>
      <small id="last-update" class="text-muted">Connecting...</small>
    </div>
    <div class="d-flex gap-2">
      <button class="btn btn-outline-secondary btn-sm" onclick="toggleTheme()" id="theme-btn">🌙 Dark Mode</button>
      <button class="btn btn-danger btn-sm" onclick="generatePDF()">Export PDF</button>
    </div>
  </header>

  <div class="control-panel">
    <div class="row g-2 align-items-end">
      <div class="col-md-3">
        <label class="kpi-small-label">History Range</label>
        <select id="rangeSelect" class="form-select form-select-sm" onchange="fetchHistory()">
          <option value="24">Last 24 Hours</option>
          <option value="168">Last 7 Days</option>
          <option value="720">Last 30 Days</option>
        </select>
      </div>
    </div>
  </div>

  <div id="pdf-area">
    <div class="row g-3 mb-4 text-center">
      <div class="col-md-2 col-4"><div class="card kpi-card ribbon-card p-2"><div class="kpi-small-label">Air Temp</div><div class="kpi-main-val"><span id="v-at">--</span>°C</div></div></div>
      <div class="col-md-2 col-4"><div class="card kpi-card ribbon-card p-2" style="border-color:#3498db"><div class="kpi-small-label">Air Hum</div><div class="kpi-main-val"><span id="v-ah">--</span>%</div></div></div>
      <div class="col-md-2 col-4"><div class="card kpi-card ribbon-card p-2" style="border-color:#f39c12"><div class="kpi-small-label">Soil Temp</div><div class="kpi-main-val"><span id="v-st">--</span>°C</div></div></div>
      <div class="col-md-2 col-4"><div class="card kpi-card ribbon-card p-2" style="border-color:#16a085"><div class="kpi-small-label">Soil Hum</div><div class="kpi-main-val"><span id="v-sh">--</span>%</div></div></div>
      <div class="col-md-4 col-12"><div class="card kpi-card ribbon-card p-2" style="border-color:#9b59b6"><div class="kpi-small-label">Solar Intensity</div><div class="kpi-main-val"><span id="v-lx">--</span> lx</div></div></div>
    </div>

    <div class="row g-3">
      <div class="col-md-6"><div class="card kpi-card p-3"><h6 class="kpi-small-label mb-2">Atmospheric Trends</h6><div class="chart-box"><canvas id="atmoChart"></canvas></div></div></div>
      <div class="col-md-6"><div class="card kpi-card p-3"><h6 class="kpi-small-label mb-2">Soil Environment</h6><div class="chart-box"><canvas id="soilChart"></canvas></div></div></div>
      <div class="col-md-12"><div class="card kpi-card p-3"><h6 class="kpi-small-label mb-2">Light Intensity History</h6><div class="chart-box"><canvas id="luxChart"></canvas></div></div></div>
    </div>
  </div>
  <div id="map"></div>
</div>

<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
<script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<script>
  // --- CONFIG ---
  const firebaseConfig = {
        apiKey: "AIzaSyBDxPO2M4qLzJ0CPHymC6rMu4BqdZVxcYE",
        authDomain: "smart-farm-58d2e.firebaseapp.com",
        databaseURL: "https://smart-farm-58d2e-default-rtdb.asia-southeast1.firebasedatabase.app",
        projectId: "smart-farm-58d2e",
        storageBucket: "smart-farm-58d2e.firebasestorage.app",
        messagingSenderId: "607346437155",
        appId: "1:607346437155:web:2fddabc712330bdf8fd596"
    };


  if (!firebase.apps.length) { firebase.initializeApp(firebaseConfig); }
  const db = firebase.database();
  let charts = {}, map;

  function toggleTheme() {
    const body = document.documentElement;
    const isDark = body.getAttribute('data-theme') === 'dark';
    body.setAttribute('data-theme', isDark ? 'light' : 'dark');
    document.getElementById('theme-btn').innerText = isDark ? '🌙 Dark Mode' : '☀️ Light Mode';
  }

  function initMap() {
    map = L.map('map').setView([13.7563, 100.5018], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);
    L.marker([13.7563, 100.5018]).addTo(map);
  }

  // --- REAL-TIME LISTENER ---
  // Using the exact path that worked in your older version
  db.ref('locations/location-1/latest').on('value', (snap) => {
    const data = snap.val();
    if (data) {
        document.getElementById('v-at').innerText = data.ambient_temp || "0";
        document.getElementById('v-ah').innerText = data.ambient_hum || "0";
        document.getElementById('v-st').innerText = data.soil_temp || "0";
        document.getElementById('v-sh').innerText = data.soil_hum || "0";
        document.getElementById('v-lx').innerText = data.lux || "0";
        document.getElementById('last-update').innerText = "Live: " + new Date(data.ts).toLocaleTimeString();
        document.getElementById('sync-dot').className = "badge rounded-pill bg-success";
    }
  });

  // --- DUAL AXIS HISTORY ---
  function fetchHistory() {
    const hrs = document.getElementById('rangeSelect').value;
    const cutoff = Date.now() - (hrs * 3600000);

    db.ref('locations/location-1/logs').orderByChild('ts').startAt(cutoff).once('value', (snapshot) => {
      const labs = [], at = [], ah = [], st = [], sh = [], lx = [];
      snapshot.forEach(child => {
        const v = child.val();
        labs.push(new Date(v.ts).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}));
        at.push(v.ambient_temp); ah.push(v.ambient_hum);
        st.push(v.soil_temp); sh.push(v.soil_hum);
        lx.push(v.lux);
      });

      renderChart('atmoChart', labs, [
          {label:'Temp', data:at, color:'#e74c3c', axis:'y'},
          {label:'Hum', data:ah, color:'#3498db', axis:'y1'}
      ]);
      renderChart('soilChart', labs, [
          {label:'Soil Temp', data:st, color:'#f39c12', axis:'y'},
          {label:'Soil Hum', data:sh, color:'#16a085', axis:'y1'}
      ]);
      renderChart('luxChart', labs, [
          {label:'Lux', data:lx, color:'#9b59b6', axis:'y', fill: true}
      ]);
    });
  }

  function renderChart(id, labels, datasets) {
    if(charts[id]) charts[id].destroy();
    const hasSecondAxis = datasets.some(d => d.axis === 'y1');
    
    charts[id] = new Chart(document.getElementById(id), {
      type: 'line',
      data: {
        labels: labels,
        datasets: datasets.map(d => ({
          label: d.label, data: d.data, borderColor: d.color, 
          backgroundColor: d.fill ? d.color + '22' : 'transparent',
          yAxisID: d.axis, tension: 0.3, pointRadius: 0, fill: d.fill || false
        }))
      },
      options: {
        responsive: true, maintainAspectRatio: false,
        scales: {
          y: { type: 'linear', display: true, position: 'left' },
          y1: { type: 'linear', display: hasSecondAxis, position: 'right', grid: { drawOnChartArea: false } }
        }
      }
    });
  }

  function generatePDF() {
    const element = document.getElementById('pdf-area');
    html2pdf().from(element).set({ margin: 10, filename: 'Node_Report.pdf', jsPDF: { orientation: 'landscape' } }).save();
  }

  window.onload = () => { initMap(); fetchHistory(); };
</script>
</body>
</html>
